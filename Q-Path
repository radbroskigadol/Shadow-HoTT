def _run_smoke_tests() -> None:
    # H sanity: Y -> -Y, H^2 = I
    s = ShadowState(1)
    s._maybe_store_score("+Y", 1.0, 0.0)
    s._maybe_store_score("-Y", 0.0, 1.0)
    s.refresh_cache()
    t = apply_gate(s, "H", target_wire=0)
    assert t.bi.get("-Y") == [1.0, 0.0], "H should map +Y to -Y"
    tt = apply_gate(t, "H", target_wire=0)
    assert tt.bi.get("+Y") == [1.0, 0.0], "H^2 should restore +Y"

    # S sanity: X -> Y, Y -> -X
    s2 = ShadowState(1)
    s2._maybe_store_score("+X", 1.0, 0.0)
    s2.refresh_cache()
    u = apply_gate(s2, "S", target_wire=0)
    assert u.bi.get("+Y") == [1.0, 0.0], "S should map +X to +Y"

    s3 = ShadowState(1)
    s3._maybe_store_score("+Y", 1.0, 0.0)
    s3.refresh_cache()
    v = apply_gate(s3, "S", target_wire=0)
    assert v.bi.get("-X") == [1.0, 0.0], "S should map +Y to -X"

    # CNOT sanity: +XI -> +XX
    s4 = ShadowState(2)
    s4._maybe_store_score("+XI", 1.0, 0.0)
    s4.refresh_cache()
    c = apply_gate(s4, "CNOT", target_wire=1, control_wire=0)
    assert c.bi.get("+XX") == [1.0, 0.0], "CNOT should map XI -> XX"

    # Measurement returns valid state and writes event labels
    m = apply_measurement(c, wire=0)
    assert isinstance(m, ShadowState)
    assert "EV:0:0" in m.bi or "EV:0:1" in m.bi

    # Sparse mode basic run
    sparse_trace = execute_circuit(
        [Instruction("H", target=0), Instruction("S", target=0), Instruction("MEASURE", target=0)],
        num_wires=1,
        sparse=True,
    )
    assert len(sparse_trace) == 4

    # Transport soundness harness (small)
    verify_transport_soundness(max_qubits=2)


